# ======================================================================
# Database
# ======================================================================
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ======================================================================
# LLM — Production path (preferred)
# ======================================================================
# Harvard API Portal exposes Google Gemini API.
# Apply at https://api.harvard.edu/ — pay-as-you-go with HarvardKey auth.
HARVARD_PORTAL_GEMINI_API_KEY=
HARVARD_PORTAL_GEMINI_BASE_URL=https://api.harvard.edu/gemini/v1

# Default model: Gemini 3.1 Flash Lite (preview as of late March 2026).
# Pin to a snapshot ID when one is published (e.g., gemini-3.1-flash-lite-preview-03-2026).
DEFAULT_MODEL_ID=gemini-3.1-flash-lite-preview

# ======================================================================
# LLM — Demo path (direct Google API, for development before Harvard
# portal access is provisioned). Use with synthetic test data only.
# ======================================================================
GEMINI_API_KEY=
USE_DEMO_API=false  # flip to true if Harvard portal not yet provisioned

# ======================================================================
# LLM — Emergency fallback
# ======================================================================
# If Gemini 3.1 Flash Lite preview is deprecated before our demo, swap
# to Claude Haiku 4.5. Two-line change in backend/lib/provider.ts.
ANTHROPIC_API_KEY=
FALLBACK_MODEL_ID=claude-haiku-4-5-20251001

# ======================================================================
# CORS — origin allowed to embed the frontend in iframe
# ======================================================================
ALLOWED_IFRAME_ORIGIN=https://canvas.harvard.edu

# ======================================================================
# Backend server
# ======================================================================
PORT=3001
NODE_ENV=development

# ======================================================================
# Logging
# ======================================================================
LOG_LEVEL=info
